# ==========================================================================
# .gitattributes – sorgt im gemischten Team (Windows + macOS) für
# einheitliche Zeilenenden und verhindert "Phantom-Änderungen" in Diffs.
# Diese Datei wird committed (gehört für alle gleich ins Repo).
# ==========================================================================

# Standard: Git normalisiert alle Textdateien intern auf LF.
# eol=lf erzwingt LF auch in der Arbeitskopie – einheitlich auf allen Systemen.
* text=auto eol=lf

# --- Quellcode & Konfiguration: explizit als Text (LF) ---
*.java   text eol=lf
*.xml    text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.md     text eol=lf
*.txt    text eol=lf
*.properties text eol=lf
.gitignore   text eol=lf
.gitattributes text eol=lf

# --- Windows-Skripte MÜSSEN CRLF behalten, sonst laufen sie nicht ---
*.bat    text eol=crlf
*.cmd    text eol=crlf

# --- Maven Wrapper Skripte ---
mvnw     text eol=lf
mvnw.cmd text eol=crlf

# --- Binärdateien: niemals anfassen / nie als Text behandeln ---
*.jar    binary
*.class  binary
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.pdf    binary
